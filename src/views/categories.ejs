<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Service Project Categories</h2>

    <% if (categories && categories.length > 0) { %>
        <ul>
            <% categories.forEach((category) => { %>
                <li><%= category.name %></li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No categories are available right now.</p>
    <% } %>
</main>

<%- include('partials/footer') %>
