<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <p>Here are a few of our partner organizations:</p>

    <% if (organizations && organizations.length > 0) { %>
        <ul>
            <% organizations.forEach((organization) => { %>
                <li>
                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                    <strong><a href="/organization/<%= organization.organization_id %>"><%= organization.name %></a></strong>
                    <p><%= organization.description %></p>
                    <p>Contact: <a href="mailto:<%= organization.contact_email %>"><%= organization.contact_email %></a></p>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No organizations are available right now.</p>
    <% } %>

    <p><a href="/new-organization">Add a new organization</a></p>
</main>

<%- include('partials/footer') %>
