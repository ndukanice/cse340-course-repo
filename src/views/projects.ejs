<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <% if (projects && projects.length > 0) { %>
        <ul>
            <% projects.forEach((project) => { %>
                <% 
                    const projectDate = new Date(project.date);
                    const formattedDate = projectDate.toLocaleDateString('en-US', { 
                        weekday: 'long', 
                        year: 'numeric', 
                        month: 'long', 
                        day: 'numeric' 
                    });
                %>
                <li>
                    <strong>
                        <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                    </strong>
                    <p>
                        <%= formattedDate %>
                        | Organization:
                        <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                    </p>
                    <p><%= project.description %></p>
                    <p><strong>Location:</strong> <%= project.location %></p>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No projects are available right now.</p>
    <% } %>

    <p><a href="/new-project">Add a New Service Project</a></p>
</main>

<%- include('partials/footer') %>
