<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <h2><%= projectDetails.title %></h2>

    <p><strong>Description:</strong> <%= projectDetails.description %></p>

    <% const projectDate = new Date(projectDetails.date); %>
    <p>
        <strong>Date:</strong>
        <%= projectDate.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
    </p>

    <p><strong>Location:</strong> <%= projectDetails.location %></p>

    <p>
        <strong>Organization:</strong>
        <a href="/organization/<%= projectDetails.organization_id %>"><%= projectDetails.organization_name %></a>
    </p>

    <p><a href="/edit-project/<%= projectDetails.project_id %>">Edit Project</a></p>

    <p>
        <strong>Categories:</strong>
        <% if (categories && categories.length > 0) { %>
            <% categories.forEach((category, index) => { %>
                <a href="/category/<%= category.category_id %>"><%= category.name %></a><%= index < categories.length - 1 ? ', ' : '' %>
            <% }) %>
        <% } else { %>
            None
        <% } %>
    </p>

    <p><a href="/assign-categories/<%= projectDetails.project_id %>">Edit Categories</a></p>
</main>
<%- include('partials/footer') %>
