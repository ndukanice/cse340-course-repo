<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <% const projectDateForInput = new Date(projectDetails.date).toISOString().split('T')[0]; %>

    <form action="/edit-project/<%= projectDetails.project_id %>" method="POST">
        <div class="form-group">
            <label for="organizationId">Organization</label>
            <select id="organizationId" name="organizationId" required>
                <% organizations.forEach((organization) => { %>
                    <option
                        value="<%= organization.organization_id %>"
                        <%= organization.organization_id === projectDetails.organization_id ? 'selected' : '' %>
                    >
                        <%= organization.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="form-group">
            <label for="title">Project Title</label>
            <input
                type="text"
                id="title"
                name="title"
                required
                maxlength="200"
                value="<%= projectDetails.title %>"
            />
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea
                id="description"
                name="description"
                required
                maxlength="1000"
            ><%= projectDetails.description %></textarea>
        </div>

        <div class="form-group">
            <label for="location">Location</label>
            <input
                type="text"
                id="location"
                name="location"
                required
                maxlength="200"
                value="<%= projectDetails.location %>"
            />
        </div>

        <div class="form-group">
            <label for="date">Date</label>
            <input
                type="date"
                id="date"
                name="date"
                required
                value="<%= projectDateForInput %>"
            />
        </div>

        <button type="submit">Update Service Project</button>
    </form>
</main>
<%- include('partials/footer') %>
